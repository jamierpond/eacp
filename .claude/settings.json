{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/eacp-tidy.js",
            "asyncRewake": true,
            "timeout": 120,
            "statusMessage": "eacp-tidy checking edited file"
          }
        ]
      }
    ]
  }
}
