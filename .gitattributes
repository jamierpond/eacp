# Default: auto-detect text files and normalize to LF in the index and
# on checkout. Overrides any local core.autocrlf setting, so Windows
# contributors see the same line endings as macOS contributors.
#
# Note: eol=lf does NOT make a CRLF working-tree file "clean" — `git diff`
# normalizes it away, but `git status` still flags it as pending
# renormalization. Codegen must emit LF directly. In particular CMake's
# configure_file defaults to CRLF on Windows; the WebView generators pass
# NEWLINE_STYLE LF so the generated .ts files don't show up perpetually dirty.
* text=auto eol=lf

# Explicit binary overrides — never touch line endings.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.icns binary
*.mp3  binary
*.wav  binary
*.ogg  binary
*.mp4  binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.tgz  binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.otf  binary
*.dll  binary
*.exe  binary
*.lib  binary
*.dylib binary
*.so   binary

# Windows-only files keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
